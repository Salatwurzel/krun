#!/usr/bin/env -S java --source 21

class krun{
    public static void main(String[] args) {
        if(args.length > 0){
            var pb = new ProcessBuilder(
                "/usr/bin/env", 
                "kotlinc", 
                args[0],
                "-include-runtime",
                "-d",
                args[0].replace(".kt", ".jar")
            );

            var pb2 = new ProcessBuilder(
                "/usr/bin/env", 
                "java",
                "-jar",
                args[0].replace(".kt", ".jar") 
            );

            try {
                pb.inheritIO().start();
                System.out.println("\n");
                pb2.inheritIO().start();
            } 
            catch (Exception e){}
        }

        else{
            System.out.println("Usage: krun <file.kt>");
        }
    }
}